                </Box>
              </Collapse>
            </FilterSection>

            <Divider />

            <FilterSection>
              <FilterSectionHeader button onClick={() => toggleSection('workStatus')}>
                <ListItemText
                  primary="Work Status"
                  secondary={`${filters.workStatus.length}/${workStatusOptions.length}`}
                  secondaryTypographyProps={{ variant: 'caption' }}
