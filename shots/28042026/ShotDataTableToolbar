            edge="start"
            checked={isChildSelected(section, option.id)}
            size="small"
            disableRipple
            style={{ 
              padding: 4, 
              color: '#dbe1e7', 
            }}
          />
          <ListItemText
            primary={option.label}
            primaryTypographyProps={{ variant: 'body2'}}
          />
        </ListItem>
      ));
    }
  };

