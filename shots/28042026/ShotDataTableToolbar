        style={{
          height: 28,
          textTransform: 'none',
          fontSize: 12,
          backgroundColor: activeFilterCount > 0 ? '#00b7ff' : '#3d3d3d',
          color: '#fff',
          borderRadius: 2,
          marginRight: 8,
        }}
