const name1Options = useMemo(() => {
  let entries = Object.entries(groupCounts);

  // ✅ FILTER when something is selected
  if (filters.shotGroups.length > 0) {
    entries = entries.filter(([key]) =>
      filters.shotGroups.includes(key)
    );
  }

  const sorted = entries.sort((a, b) => b[1] - a[1]);

  return sorted.map(([key, count]) => ({
    id: key,
    label: `${key} (${count})`,
  }));
}, [groupCounts, filters.shotGroups]);
