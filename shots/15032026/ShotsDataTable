const ShotsDataTable: React.FC<ShotsDataTableProps> = ({
  project,
  shots,
  phaseComponents,
  latestComponents,
  tableFooter,
  dateTimeFormat,
  columnsState,
  filters,
  searchValue,
}) => {
  if (project == null) {
    return null;
  }
  const { reviewInfos } = useFetchShotReviewInfos(project, shots);
  const { thumbnails }  = useFetchShotThumbnails(project, shots);
  const visibleColumns  = columns.filter(column => 
    column.fixed || columnsState[column.id] !== false
  );

  // Apply filters on the frontend (temporary solution)
  const filteredShots = shots.filter(shot => {
    // Get the review info for this shot
    const shotReviewInfos = Object.entries(reviewInfos)
      .filter(([key]) => key.startsWith(shot.groups.join('-')))
      .map(([, info]) => info);

    // Check if any phase matches the approval status filters
    if (filters.approvalStatus.length > 0) {
      const matchesApproval = shotReviewInfos.some(info => 
        filters.approvalStatus.includes(info.approval_status)
      );
      if (!matchesApproval) return false;
    }

    // Check if any phase matches the work status filters
    if (filters.workStatus.length > 0) {
      const matchesWork = shotReviewInfos.some(info => 
        filters.workStatus.includes(info.work_status)
      );
      if (!matchesWork) return false;
    }

    return true;
  });

  console.log('Filtered shots:', filteredShots.length, 'out of', shots.length);

  return (
    <Table 
      stickyHeader
      style={{
        tableLayout: 'fixed',
        width: 'auto',
      }}
    >
      <RecordTableHead
        key='shot-data-table-head'
        columns={visibleColumns}
        phaseComponents={phaseComponents}
        latestComponents={latestComponents}
        columnsState={columnsState}
      />
      <TableBody>
        {filteredShots.map((shot, index) => (
          <ShotRow
            key={`${shot.groups.join('/')}-${shot.relation}-${index}`}
            shot={shot}
            reviewInfos={reviewInfos}
            thumbnails={thumbnails}
            phaseComponents={phaseComponents}
            latestComponents={latestComponents}
            dateTimeFormat={dateTimeFormat}
            isLastRow={(index === filteredShots.length - 1)}
            columnsState={columnsState}
          />
        ))}
      </TableBody>
      {tableFooter || null}
    </Table>
  );
};
