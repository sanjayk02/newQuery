const filteredShots = shots.filter((shot) => {
  if (!reviewInfos) return true;

  const shotKey = `${shot.groups[0]}-${shot.groups[1]}-${shot.groups[2]}`;

  const reviewInfosForShot = Object.entries(reviewInfos)
    .filter(([key]) => key.startsWith(shotKey))
    .map(([, value]) => value);

  return reviewInfosForShot.length > 0;
});
