package repository

import (
	"fmt"
	"strings"

	"github.com/PolygonPictures/central30-web/front/entity"
	"gorm.io/gorm"
)

// ListFilteredShotsPaginated finds unique shots whose LATEST status per phase
// matches the given approval/work status filters.
// Uses a subquery to get the latest record per (group_1,group_2,group_3,relation,phase)
// before applying status filters — so old statuses don't cause false matches.
func (r *ReviewInfo) ListFilteredShotsPaginated(
	db *gorm.DB,
	project string,
	approvalStatus []string,
	workStatus []string,
	search *string,
	page int,
	perPage int,
) ([]*entity.ShotDocument, int64, error) {

	// Step 1: Subquery — get the latest modified_at_utc per
	// (group_1, group_2, group_3, relation, phase)
	// This ensures we only check CURRENT status, not historical ones
	latestPerPhase := db.Model(&model.ReviewInfo{}).
		Select(
			"group_1, group_2, group_3, relation, phase,"+
				" MAX(modified_at_utc) AS modified_at_utc",
		).
		Where("project = ?", project).
		Where("root = ?", "shots").
		Where("deleted = 0").
		Group("group_1, group_2, group_3, relation, phase")

	// Step 2: Join back to get the full row for each latest record
	// then filter by status
	latest := db.Select("b.group_1, b.group_2, b.group_3, b.relation,"+
		" b.approval_status, b.work_status").
		Table("(?) AS a", latestPerPhase).
		Joins(
			"JOIN t_review_info b ON"+
				" a.group_1 = b.group_1"+
				" AND a.group_2 = b.group_2"+
				" AND a.group_3 = b.group_3"+
				" AND a.relation = b.relation"+
				" AND a.phase = b.phase"+
				" AND a.modified_at_utc = b.modified_at_utc"+
				" AND b.project = ?"+
				" AND b.root = 'shots'"+
				" AND b.deleted = 0",
			project,
		)

	// Step 3: Apply status filters on latest records only
	conditions := []string{}
	args := []interface{}{}

	if len(approvalStatus) > 0 {
		conditions = append(conditions, "b.approval_status IN ?")
		args = append(args, approvalStatus)
	}
	if len(workStatus) > 0 {
		conditions = append(conditions, "b.work_status IN ?")
		args = append(args, workStatus)
	}

	// OR between approval and work status filters
	if len(conditions) > 0 {
		latest = latest.Where(strings.Join(conditions, " OR "), args...)
	}

	// Step 4: Group unique shots and apply search
	outer := db.Select("group_1, group_2, group_3, relation").
		Table("(?) AS latest", latest).
		Group("group_1, group_2, group_3, relation").
		Order("group_1 ASC, group_2 ASC, group_3 ASC")

	if search != nil && strings.TrimSpace(*search) != "" {
		s := strings.TrimSpace(*search) + "%" // starts-with
		outer = outer.Where(
			"group_1 LIKE ? OR group_2 LIKE ? OR group_3 LIKE ?",
			s, s, s,
		)
	}

	type uniqueShot struct {
		Group1   string `gorm:"column:group_1"`
		Group2   string `gorm:"column:group_2"`
		Group3   string `gorm:"column:group_3"`
		Relation string `gorm:"column:relation"`
	}

	var rows []uniqueShot
	if err := outer.Scan(&rows).Error; err != nil {
		return nil, 0, fmt.Errorf("ListFilteredShotsPaginated: %w", err)
	}

	total := int64(len(rows))

	// Paginate in Go
	offset := (page - 1) * perPage
	if offset >= len(rows) {
		return []*entity.ShotDocument{}, total, nil
	}
	end := offset + perPage
	if end > len(rows) {
		end = len(rows)
	}
	rows = rows[offset:end]

	shots := make([]*entity.ShotDocument, len(rows))
	for i, row := range rows {
		shots[i] = &entity.ShotDocument{
			Groups:   []string{row.Group1, row.Group2, row.Group3},
			Relation: row.Relation,
		}
	}
	return shots, total, nil
}
