// Add these states near the top of the ShotsDataTablePanel component
const [isColumnStateLoaded, setIsColumnStateLoaded] = useState(false);
const [pendingHiddenIds, setPendingHiddenIds] = useState<string[] | null>(null);

// Remove the localStorage-related functions and constants
// Remove: PIPE_KEY_SHOTS, FIXED_VISIBLE_IDS, lsKeyForProject, persistHiddenColumnsLocal

// Keep only the pipeline key constant
const PIPE_KEY_SHOTS = '/ppiTracker/shots/hiddenColumns';
const FIXED_VISIBLE_IDS = new Set(['thumbnail', 'group_1_name', 'group_2_name', 'group_3_name']);

// Load column visibility from pipeline settings only (no localStorage)
useEffect(() => {
    let isMounted = true;
    
    const loadColumnVisibility = async () => {
        if (!currentProject || !currentProject.key_name) {
            setIsColumnStateLoaded(true);
            return;
        }
        
        const projectKey = currentProject.key_name;
        
        try {
            const pipelineApi = await import('../../../new-pipeline-setting/api') as any;
            const { GROUP, SECTION } = await import('../../../new-pipeline-setting/types');
            
            // Try to load from pipeline settings
            let savedValue = null;
            
            if (typeof pipelineApi.queryValue === 'function') {
                savedValue = await pipelineApi.queryValue(
                    GROUP.Preference,
                    SECTION.Project,
                    projectKey,
                    PIPE_KEY_SHOTS,
                );
            } else if (typeof pipelineApi.queryConfig === 'function') {
                savedValue = await pipelineApi.queryConfig(
                    'project',
                    projectKey,
                    PIPE_KEY_SHOTS,
                );
            }
            
            if (isMounted) {
                if (savedValue && Array.isArray(savedValue)) {
                    setPendingHiddenIds(savedValue);
                    console.log('[ColumnVisibility] Loaded from pipeline:', savedValue);
                } else {
                    setPendingHiddenIds([]);
                    console.log('[ColumnVisibility] No saved columns, using defaults');
                }
                setIsColumnStateLoaded(true);
            }
        } catch (e) {
            console.warn('[ColumnVisibility] Pipeline load failed:', e);
            if (isMounted) {
                setPendingHiddenIds([]);
                setIsColumnStateLoaded(true);
            }
        }
    };
    
    loadColumnVisibility();
    
    return () => { 
        isMounted = false;
    };
}, [currentProject]);

// Build default columns after phaseComponents and saved state are loaded
useEffect(() => {
    // Wait for both phaseComponents to load AND column visibility to be loaded
    if (Object.keys(phaseComponents || {}).length > 0 && 
        isColumnStateLoaded && 
        Object.keys(columnsState).length === 0) {
        
        // Build default state
        const defaultState = buildDefaultColumnState(phaseComponents);
        
        // Apply hidden columns from pipeline settings
        if (pendingHiddenIds && pendingHiddenIds.length > 0) {
            pendingHiddenIds.forEach(id => {
                if (!FIXED_VISIBLE_IDS.has(id) && defaultState.hasOwnProperty(id)) {
                    defaultState[id] = false;
                }
            });
            console.log('[ColumnVisibility] Applied hidden columns:', pendingHiddenIds);
        }
        
        setColumnsState(defaultState);
    }
}, [phaseComponents, columnsState, isColumnStateLoaded, pendingHiddenIds]);

// Save to pipeline settings only (no localStorage)
const saveToPipelineSettings = useCallback(async (hiddenIds: string[]) => {
    if (!currentProject || !currentProject.key_name) return;
    
    try {
        const { updateValue } = await import('../../../new-pipeline-setting/api');
        const { GROUP, SECTION } = await import('../../../new-pipeline-setting/types');
        
        await updateValue(
            PIPE_KEY_SHOTS,
            hiddenIds,
            GROUP.Preference,
            SECTION.Project,
            currentProject.key_name,
        );
        console.log('[ColumnVisibility] Saved to pipeline:', hiddenIds);
    } catch (e) {
        console.warn('[ColumnVisibility] Pipeline save failed:', e);
        throw e; // Re-throw so the UI can handle the error if needed
    }
}, [currentProject]);

// Save columns handler (no localStorage)
const handleSaveColumns = useCallback(async () => {
    // Get hidden column IDs (where value is false)
    const hiddenIds = Object.entries(columnsState)
        .filter(([id, visible]) => !visible && !FIXED_VISIBLE_IDS.has(id))
        .map(([id]) => id);
    
    // Save to pipeline
    await saveToPipelineSettings(hiddenIds);
    
    console.log('[ColumnVisibility] Saved columns:', hiddenIds);
}, [columnsState, saveToPipelineSettings]);
