import React, {
    FC,
    useEffect,
    useMemo,
    useRef,
    useState,
} from 'react';
import { RouteComponentProps } from "react-router-dom";
import { CircularProgress, Container, Paper, styled } from '@material-ui/core';
import { TablePaginationProps } from '@material-ui/core/TablePagination';
import { useShotsPivot, useFetchPipelineSettingShotComponents, useFetchLatestShotComponents } from './hooks';
import { PageProps, ShotPivot } from './types';
import ShotsDataTable from './ShotsDataTable';
import ShotsDataTableFooter from './ShotsDataTableFooter';
import { useCurrentProject } from '../../hooks';
import { useCurrentStudio } from '../../../studio/hooks';
import { queryConfig } from '../../../new-pipeline-setting/api';
import ShotDataTableToolbar, {
    ViewMode,
    ColumnState,
    DEFAULT_COLUMN_STATE,
} from './ShotDataTableToolbar';

import ShotsDataTableGroup, { getShotSortValue } from './ShotsDataTableGroup';

const StyledContainer = styled(Container)(({ theme }) => ({
    position: 'relative',
    display: 'flex',
    flexDirection: 'column',
    padding: 0,
    '& > *': {
        display: 'flex',
        overflow: 'hidden',
        padding: theme.spacing(1),
        paddingBottom: 0,
    },
    '& > *:last-child': {
        paddingBottom: theme.spacing(1),
    },
}));

const StyledPaper = styled(Paper)({
    width: '100%',
    display: 'flex',
    flexDirection: 'column',
    overflow: 'auto',
    flex: '1 1 auto',
});

const StyledContentDiv = styled('div')(({ theme }) => ({
    backgroundColor: theme.palette.background.paper,
    display: 'flex',
    flexDirection: 'row',
    gap: theme.spacing(2),
    width: 'fit-content',
    minWidth: '100%',
}));

const StyledTableDiv = styled('div')({
    paddingBottom: 8,
    overflowX: 'auto',
    width: '100%',
    flex: '1 1 auto',
    height: '100%',
});

const ToolBarWrapper = styled('div')(({ theme }) => ({
    display: 'flex',
    flexDirection: 'column',
    gap: theme.spacing(1),
}));

const FooterWrapper = styled('div')(({ theme }) => ({
    display: 'flex',
    justifyContent: 'flex-end',
    width: '100%',
    backgroundColor: theme.palette.background.paper,
    paddingRight: theme.spacing(25),
}));

const ShotsDataTablePanel: FC<RouteComponentProps> = () => {

    const [viewMode, setViewMode] = useState<ViewMode>('list');
    const [searchValue, setSearchValue] = useState<string>('');
    const [columnsState, setColumnsState] = useState<ColumnState>(DEFAULT_COLUMN_STATE);

    const [pageProps, setPageProps] = useState<PageProps>({ page: 0, rowsPerPage: 15 });

    const { currentProject } = useCurrentProject();
    const { phaseComponents } = useFetchPipelineSettingShotComponents(currentProject);

    // ✅ FIXED DEFAULT SORT
    const [sortKey, setSortKey] = useState<string>('group3_only');
    const [sortDir, setSortDir] = useState<'asc' | 'desc'>('asc');

    const isGroupView = viewMode === 'group';

    const { shots, total, groupCounts, loading } = useShotsPivot({
        project: currentProject,
        page: isGroupView ? 1 : pageProps.page + 1,
        perPage: isGroupView ? 10000 : pageProps.rowsPerPage,
        nameKey: searchValue,
        approvalStatus: [],
        workStatus: [],
        orderKey: isGroupView ? 'group1_only' : sortKey,
        direction: isGroupView ? 'ASC' : sortDir.toUpperCase(),
        shotsGroups: [],
    });

    // ✅ COMPONENT DATA
    const shotsForComponents = useMemo(() => {
        return (shots || []).map(s => ({
            groups: [s.group_1, s.group_2, s.group_3],
            relation: s.relation,
        }));
    }, [shots]);

    const { latestComponents } = useFetchLatestShotComponents(
        currentProject,
        shotsForComponents,
        phaseComponents
    );

    // ✅ FIXED SORT
    const sortedAllShots = useMemo(() => {
        if (!isGroupView || !shots || shots.length === 0) return shots || [];

        // ✅ FIX: no empty return
        if (shots.length < total) return shots;

        const smartCmp = (a: string, b: string) => {
            const isNumA = /^\d+$/.test(a);
            const isNumB = /^\d+$/.test(b);
            if (isNumA && isNumB) return parseInt(a, 10) - parseInt(b, 10);
            if (isNumA) return -1;
            if (isNumB) return 1;
            return a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' });
        };

        const arr = [...shots];

        arr.sort((a, b) => {

            const g1 = a.group_1.toLowerCase().localeCompare(b.group_1.toLowerCase());
            if (g1 !== 0) return g1;

            const g2 = smartCmp(a.group_2, b.group_2);
            if (g2 !== 0) return g2;

            // ✅ SAFE COMPONENT SORT
            const aVal = latestComponents
                ? getShotSortValue(a, sortKey, latestComponents)
                : '';

            const bVal = latestComponents
                ? getShotSortValue(b, sortKey, latestComponents)
                : '';

            if (aVal === bVal) return 0;

            return sortDir === 'asc'
                ? (aVal > bVal ? 1 : -1)
                : (aVal < bVal ? 1 : -1);
        });

        return arr;

    }, [shots, total, isGroupView, sortKey, sortDir, latestComponents]);

    const pagedShots = useMemo(() => {
        if (!isGroupView) return shots;
        const start = pageProps.page * pageProps.rowsPerPage;
        return sortedAllShots.slice(start, start + pageProps.rowsPerPage);
    }, [isGroupView, sortedAllShots, shots, pageProps]);

    const handleSortChange = (key: string) => {
        if (sortKey === key) {
            setSortDir(sortDir === 'asc' ? 'desc' : 'asc');
        } else {
            setSortKey(key);
            setSortDir('asc');
        }
    };

    return (
        <StyledContainer maxWidth="xl">
            <ToolBarWrapper>
                <ShotDataTableToolbar
                    viewMode={viewMode}
                    onViewChange={setViewMode}
                    searchValue={searchValue}
                    onSearchChange={setSearchValue}
                    filters={{ shotGroups: [], approvalStatus: [], workStatus: [] }}
                    onFilterChange={() => {}}
                    columnsState={columnsState}
                    onColumnsChange={setColumnsState}
                    shotGroupOptions={[]}
                />
            </ToolBarWrapper>

            <StyledTableDiv>
                <StyledPaper>
                    {loading ? (
                        <CircularProgress />
                    ) : (
                        <StyledContentDiv>
                            {viewMode === 'group' ? (
                                <ShotsDataTableGroup
                                    project={currentProject}
                                    shots={pagedShots}
                                    total={groupCounts}
                                    phaseComponents={phaseComponents}
                                    columnsState={columnsState}
                                    sortKey={sortKey}
                                    sortDir={sortDir}
                                    onSortChange={handleSortChange}
                                    latestComponents={latestComponents} // ✅ PASS DOWN
                                />
                            ) : (
                                <ShotsDataTable
                                    project={currentProject}
                                    shots={shots}
                                    total={groupCounts}
                                    phaseComponents={phaseComponents}
                                    columnsState={columnsState}
                                    sortKey={sortKey}
                                    sortDir={sortDir}
                                    onSortChange={handleSortChange}
                                />
                            )}
                        </StyledContentDiv>
                    )}
                </StyledPaper>
            </StyledTableDiv>

            <FooterWrapper>
                <ShotsDataTableFooter
                    count={total}
                    page={pageProps.page}
                    rowsPerPage={pageProps.rowsPerPage}
                    onChangePage={(_, p) => setPageProps(prev => ({ ...prev, page: p }))}
                    onChangeRowsPerPage={e => setPageProps({ page: 0, rowsPerPage: parseInt(e.target.value) })}
                />
            </FooterWrapper>
        </StyledContainer>
    );
};

export default ShotsDataTablePanel;
