const filteredShots = shots.filter(shot => {

  const key = `${shot.groups[0]}-${shot.groups[1]}-${shot.groups[2]}`

  const infos = Object.values(reviewInfos).filter(info =>
    info.groups.join('-') === key
  )

  if (filters.approvalStatus.length > 0) {
    if (!infos.some(info =>
      filters.approvalStatus.includes(info.approval_status)
    )) {
      return false
    }
  }

  if (filters.workStatus.length > 0) {
    if (!infos.some(info =>
      filters.workStatus.includes(info.work_status)
    )) {
      return false
    }
  }

  return true
})
