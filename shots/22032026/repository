package repository

import (
    "context"
    "database/sql"
    "fmt"
    "strings"
    "time"
)

// shotKey represents a unique identifier for a shot
type shotKey struct {
    Group1    string
    Group2    string
    Group3    string
    Relation  string
    Component string
}

// ShotPivot represents a shot with all its phase data
type ShotPivot struct {
    Root      string
    Project   string
    Group1    string
    Group2    string
    Group3    string
    Relation  string
    Component string
    Phases    map[string]PhaseData
}

// PhaseData contains the status information for a specific phase
type PhaseData struct {
    WorkStatus     *string
    ApprovalStatus *string
    SubmittedAtUTC *time.Time
    Take           *string
}

// SortField represents valid sort field types
type SortField string

const (
    SortByGroup1         SortField = "group1"
    SortByGroup2         SortField = "group2"
    SortByGroup3         SortField = "group3"
    SortByRelation       SortField = "relation"
    SortByWorkStatus     SortField = "work_status"
    SortByApprovalStatus SortField = "approval_status"
    SortBySubmittedAt    SortField = "submitted_at"
    SortByTake           SortField = "take"
)

// SortRequest represents a sorting request
type SortRequest struct {
    Field     SortField
    Direction string
    Phase     string // Optional, for phase-specific sorts (e.g., "lay", "anm")
}

// Validation constants
const (
    MaxPerPage = 100
    MinPerPage = 1
    DefaultPerPage = 20
)

// =========================
// BUILD SHOT ORDER CLAUSE (IMPROVED)
// =========================

// buildShotOrderClause constructs an ORDER BY clause for shot listings.
//
// Parameters:
//   - alias: Table alias to prefix column names (empty if no alias)
//   - sortKey: Sort key in format "field" or "phase_field" (e.g., "group1", "lay_work")
//   - dir: Sort direction ("ASC" or "DESC"). Defaults to "ASC" if invalid.
//
// Valid sort keys:
//   - Simple: group1, group2, group3, relation
//   - Work status: {phase}_work (phase: lay, anm, gnz, mat, dsp, cloth, cfxhair, crd, drw, rtcgnz, rtcmat, rtcmatnuke, rtcdrw)
//   - Approval status: {phase}_appr (same phases as work status)
//   - Submitted date: {phase}_submitted (phases: lay, anm, gnz, mat)
//   - Take number: {phase}_take (phases: lay, anm, gnz, mat)
//
// The function handles NULL values by placing them first for status fields
// and take numbers to ensure consistent ordering.
func buildShotOrderClause(alias, sortKey, dir string) (string, error) {
    // Validate direction
    dir = strings.ToUpper(strings.TrimSpace(dir))
    if dir != "ASC" && dir != "DESC" {
        dir = "ASC"
    }

    // Define allowed sort keys
    allowedKeys := map[string]bool{
        // Group and relation sorts
        "group1":   true,
        "group2":   true,
        "group3":   true,
        "relation": true,
        
        // Work status sorts
        "lay_work": true, "anm_work": true, "gnz_work": true, "mat_work": true,
        "dsp_work": true, "cloth_work": true, "cfxhair_work": true, "crd_work": true, "drw_work": true,
        "rtcgnz_work": true, "rtcmat_work": true, "rtcmatnuke_work": true, "rtcdrw_work": true,
        
        // Approval status sorts
        "lay_appr": true, "anm_appr": true, "gnz_appr": true, "mat_appr": true,
        "dsp_appr": true, "cloth_appr": true, "cfxhair_appr": true, "crd_appr": true, "drw_appr": true,
        "rtcgnz_appr": true, "rtcmat_appr": true, "rtcmatnuke_appr": true, "rtcdrw_appr": true,
        
        // Submitted date sorts
        "lay_submitted": true, "anm_submitted": true, "gnz_submitted": true, "mat_submitted": true,
        
        // Take sorts
        "lay_take": true, "anm_take": true, "gnz_take": true, "mat_take": true,
    }
    
    if !allowedKeys[sortKey] {
        return "", fmt.Errorf("invalid sort key: %s", sortKey)
    }

    col := func(c string) string {
        if alias == "" {
            return c
        }
        return alias + "." + c
    }

    // Group and relation sorts
    if sortKey == "group1" {
        return fmt.Sprintf(`
            LOWER(%s) %s,
            LOWER(%s) ASC,
            LOWER(%s) ASC
        `,
            col("group_1"), dir,
            col("group_2"),
            col("group_3"),
        ), nil
    }
    
    if sortKey == "group2" {
        return fmt.Sprintf(`
            LOWER(%s) %s,
            LOWER(%s) ASC,
            LOWER(%s) ASC
        `,
            col("group_2"), dir,
            col("group_1"),
            col("group_3"),
        ), nil
    }
    
    if sortKey == "group3" {
        return fmt.Sprintf(`
            LOWER(%s) %s,
            LOWER(%s) ASC,
            LOWER(%s) ASC
        `,
            col("group_3"), dir,
            col("group_1"),
            col("group_2"),
        ), nil
    }
    
    if sortKey == "relation" {
        return fmt.Sprintf(`
            LOWER(%s) %s,
            LOWER(%s) ASC
        `,
            col("relation"), dir,
            col("group_1"),
        ), nil
    }

    // Work status and approval status sorts
    if strings.HasSuffix(sortKey, "_work") || strings.HasSuffix(sortKey, "_appr") {
        statusField := "work_status"
        if strings.HasSuffix(sortKey, "_appr") {
            statusField = "approval_status"
        }
        
        return fmt.Sprintf(`
            (CASE WHEN %s IS NULL OR %s = '-' OR %s = '' THEN 1 ELSE 0 END) ASC,
            LOWER(%s) %s,
            LOWER(%s) ASC,
            LOWER(%s) ASC,
            LOWER(%s) ASC
        `,
            col(statusField), col(statusField), col(statusField),
            col(statusField), dir,
            col("group_1"),
            col("group_2"),
            col("group_3"),
        ), nil
    }

    // Submitted date sorts
    if strings.HasSuffix(sortKey, "_submitted") {
        return fmt.Sprintf(`
            (%s IS NULL) ASC,
            %s %s
        `,
            col("submitted_at_utc"),
            col("submitted_at_utc"), dir,
        ), nil
    }

    // Take sorts (numeric)
    if strings.HasSuffix(sortKey, "_take") {
        return fmt.Sprintf(`
            CASE WHEN %s IS NULL OR %s = '' THEN 1 ELSE 0 END ASC,
            CAST(RIGHT(%s, 4) AS UNSIGNED) %s,
            LOWER(%s) ASC
        `,
            col("take"), col("take"),
            col("take"), dir,
            col("group_1"),
        ), nil
    }

    // This should never be reached due to validation above
    return "", fmt.Errorf("unhandled sort key: %s", sortKey)
}

// =========================
// LIST LATEST SHOTS DYNAMIC (IMPROVED)
// =========================

// ListLatestShotsDynamic retrieves a paginated list of unique shot keys
// with sorting and filtering applied.
func (r *repository) ListLatestShotsDynamic(
    ctx context.Context,
    project string,
    orderKey string,
    direction string,
    page int,
    perPage int,
    nameKey string,
    approvalStatus []string,
    workStatus []string,
) ([]shotKey, int, error) {
    
    // Input validation
    if project == "" {
        return nil, 0, fmt.Errorf("project cannot be empty")
    }
    
    if page < 1 {
        page = 1
    }
    
    if perPage < MinPerPage {
        perPage = MinPerPage
    }
    if perPage > MaxPerPage {
        perPage = MaxPerPage
    }
    
    // Validate and build order clause
    orderClause, err := buildShotOrderClause("", orderKey, direction)
    if err != nil {
        return nil, 0, fmt.Errorf("invalid order parameters: %w", err)
    }
    
    offset := (page - 1) * perPage
    
    // Build the query
    var args []any
    args = append(args, project)
    
    // Base query with CTEs
    query := fmt.Sprintf(`
WITH latest_phase AS (
    SELECT
        project,
        root,
        group_1,
        group_2,
        group_3,
        relation,
        component,
        phase,
        work_status,
        approval_status,
        submitted_at_utc,
        modified_at_utc,
        take,
        ROW_NUMBER() OVER (
            PARTITION BY project, root, group_1, group_2, group_3, relation, component, phase
            ORDER BY modified_at_utc DESC
        ) AS rn
    FROM t_review_info
    WHERE project = ?
      AND root = 'shots'
      AND deleted = 0
),

latest AS (
    SELECT *
    FROM latest_phase
    WHERE rn = 1
),

filtered AS (
    SELECT
        group_1,
        group_2,
        group_3,
        relation,
        component,
        work_status,
        approval_status,
        submitted_at_utc,
        take,
        ROW_NUMBER() OVER (ORDER BY %s) AS row_num
    FROM latest
    WHERE 1=1
`, orderClause)
    
    // Add filters
    query, args = addFilters(query, args, nameKey, workStatus, approvalStatus)
    
    // Add pagination
    query += `
)
SELECT
    group_1,
    group_2,
    group_3,
    relation,
    component
FROM filtered
WHERE row_num BETWEEN ? AND ?
ORDER BY row_num
`
    
    startRow := offset + 1
    endRow := offset + perPage
    args = append(args, startRow, endRow)
    
    // Execute query with timeout
    ctx, cancel := context.WithTimeout(ctx, 30*time.Second)
    defer cancel()
    
    rows, err := r.db.QueryContext(ctx, query, args...)
    if err != nil {
        return nil, 0, fmt.Errorf("failed to execute dynamic shot query (project=%s, page=%d): %w", 
            project, page, err)
    }
    defer rows.Close()
    
    var keys []shotKey
    for rows.Next() {
        var k shotKey
        if err := rows.Scan(
            &k.Group1,
            &k.Group2,
            &k.Group3,
            &k.Relation,
            &k.Component,
        ); err != nil {
            return nil, 0, fmt.Errorf("failed to scan row: %w", err)
        }
        keys = append(keys, k)
    }
    
    if err := rows.Err(); err != nil {
        return nil, 0, fmt.Errorf("rows iteration error: %w", err)
    }
    
    // Get total count with same filters
    total, err := r.getFilteredShotsCount(ctx, project, nameKey, workStatus, approvalStatus)
    if err != nil {
        return nil, 0, fmt.Errorf("failed to get total count: %w", err)
    }
    
    return keys, total, nil
}

// addFilters appends WHERE clauses for nameKey, workStatus, and approvalStatus filters
func addFilters(query string, args []any, nameKey string, workStatus, approvalStatus []string) (string, []any) {
    if nameKey != "" {
        query += " AND (group_1 LIKE ? OR group_2 LIKE ? OR group_3 LIKE ? OR relation LIKE ?)"
        like := "%" + nameKey + "%"
        args = append(args, like, like, like, like)
    }
    
    if len(workStatus) > 0 {
        query += " AND work_status IN (" + placeholders(len(workStatus)) + ")"
        for _, v := range workStatus {
            args = append(args, v)
        }
    }
    
    if len(approvalStatus) > 0 {
        query += " AND approval_status IN (" + placeholders(len(approvalStatus)) + ")"
        for _, v := range approvalStatus {
            args = append(args, v)
        }
    }
    
    return query, args
}

// getFilteredShotsCount returns the total count of unique shots matching the filters
func (r *repository) getFilteredShotsCount(
    ctx context.Context,
    project string,
    nameKey string,
    workStatus []string,
    approvalStatus []string,
) (int, error) {
    
    var args []any
    args = append(args, project)
    
    query := `
WITH latest_phase AS (
    SELECT
        project,
        root,
        group_1,
        group_2,
        group_3,
        relation,
        component,
        phase,
        work_status,
        approval_status,
        ROW_NUMBER() OVER (
            PARTITION BY project, root, group_1, group_2, group_3, relation, component, phase
            ORDER BY modified_at_utc DESC
        ) AS rn
    FROM t_review_info
    WHERE project = ?
      AND root = 'shots'
      AND deleted = 0
),
latest AS (
    SELECT *
    FROM latest_phase
    WHERE rn = 1
)
SELECT COUNT(DISTINCT CONCAT(group_1, '|', group_2, '|', group_3, '|', relation, '|', component))
FROM latest
WHERE 1=1
`
    
    // Add filters
    if nameKey != "" {
        query += " AND (group_1 LIKE ? OR group_2 LIKE ? OR group_3 LIKE ? OR relation LIKE ?)"
        like := "%" + nameKey + "%"
        args = append(args, like, like, like, like)
    }
    
    if len(workStatus) > 0 {
        query += " AND work_status IN (" + placeholders(len(workStatus)) + ")"
        for _, v := range workStatus {
            args = append(args, v)
        }
    }
    
    if len(approvalStatus) > 0 {
        query += " AND approval_status IN (" + placeholders(len(approvalStatus)) + ")"
        for _, v := range approvalStatus {
            args = append(args, v)
        }
    }
    
    var total int
    err := r.db.QueryRowContext(ctx, query, args...).Scan(&total)
    if err != nil {
        return 0, err
    }
    
    return total, nil
}

// placeholders generates a comma-separated list of placeholders for SQL IN clause
func placeholders(n int) string {
    if n == 0 {
        return ""
    }
    
    placeholders := make([]string, n)
    for i := range placeholders {
        placeholders[i] = "?"
    }
    return strings.Join(placeholders, ",")
}

