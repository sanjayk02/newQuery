// LIST SHOTS PIVOT (IMPROVED)
// =========================

// ListShotsPivot retrieves all phase data for a paginated list of shots
// and organizes them into a pivot structure.
func (r *repository) ListShotsPivot(
    ctx context.Context,
    project string,
    page int,
    perPage int,
    orderKey string,
    direction string,
    nameKey string,
    approvalStatus []string,
    workStatus []string,
) ([]ShotPivot, int, error) {
    
    // Input validation
    if project == "" {
        return nil, 0, fmt.Errorf("project cannot be empty")
    }
    
    if page < 1 {
        page = 1
    }
    
    if perPage < MinPerPage {
        perPage = MinPerPage
    }
    if perPage > MaxPerPage {
        perPage = MaxPerPage
    }
    
    // STEP 1: GET SORTED KEYS
    keys, total, err := r.ListLatestShotsDynamic(
        ctx,
        project,
        orderKey,
        direction,
        page,
        perPage,
        nameKey,
        approvalStatus,
        workStatus,
    )
    if err != nil {
        return nil, 0, fmt.Errorf("failed to get sorted keys: %w", err)
    }
    
    if len(keys) == 0 {
        return []ShotPivot{}, total, nil
    }
    
    // STEP 2: BUILD QUERY FOR ALL PHASES
    query, args, err := r.buildPhaseQuery(keys, project)
    if err != nil {
        return nil, 0, fmt.Errorf("failed to build phase query: %w", err)
    }
    
    // STEP 3: EXECUTE QUERY WITH TIMEOUT
    ctx, cancel := context.WithTimeout(ctx, 30*time.Second)
    defer cancel()
    
    rows, err := r.db.QueryContext(ctx, query, args...)
    if err != nil {
        return nil, 0, fmt.Errorf("failed to execute phase query: %w", err)
    }
    defer rows.Close()
    
    // STEP 4: PROCESS ROWS
    pivotMap, err := r.processPhaseRows(rows, project)
    if err != nil {
        return nil, 0, fmt.Errorf("failed to process phase rows: %w", err)
    }
    
    // STEP 5: PRESERVE ORDER
    result := r.buildOrderedResult(keys, pivotMap)
    
    return result, total, nil
}

// buildPhaseQuery constructs the SQL query to fetch phase data for specific keys
func (r *repository) buildPhaseQuery(keys []shotKey, project string) (string, []any, error) {
    var args []any
    args = append(args, project)
    
    var sb strings.Builder
    sb.WriteString(`
WITH latest_phase AS (
    SELECT
        project,
        root,
        group_1,
        group_2,
        group_3,
        relation,
        component,
        phase,
        work_status,
        approval_status,
        submitted_at_utc,
        take,
        ROW_NUMBER() OVER (
            PARTITION BY project, root, group_1, group_2, group_3, relation, component, phase
            ORDER BY modified_at_utc DESC
        ) AS rn
    FROM t_review_info
    WHERE project = ?
      AND root = 'shots'
      AND deleted = 0
)

SELECT
    group_1,
    group_2,
    group_3,
    relation,
    component,
    phase,
    work_status,
    approval_status,
    submitted_at_utc,
    take
FROM latest_phase
WHERE rn = 1
`)
    
    // Add key filters
    if len(keys) == 0 {
        return "", nil, fmt.Errorf("no keys provided")
    }
    
    // To avoid SQL injection, we use parameterized queries with placeholders
    // If keys list is very large (>1000), consider batching
    const maxKeysPerBatch = 1000
    if len(keys) > maxKeysPerBatch {
        // Log warning and consider batching
        // For now, we'll still process but might need optimization
    }
    
    sb.WriteString(" AND (")
    for i, k := range keys {
        if i > 0 {
            sb.WriteString(" OR ")
        }
        sb.WriteString("(group_1 = ? AND group_2 = ? AND group_3 = ? AND relation = ? AND component = ?)")
        args = append(args, k.Group1, k.Group2, k.Group3, k.Relation, k.Component)
    }
    sb.WriteString(")")
    
    return sb.String(), args, nil
}

// processPhaseRows scans and processes the rows from the phase query
func (r *repository) processPhaseRows(rows *sql.Rows, project string) (map[string]*ShotPivot, error) {
    type row struct {
        Group1, Group2, Group3 string
        Relation               string
        Component              string
        Phase                  string
        WorkStatus             *string
        ApprovalStatus         *string
        SubmittedAtUTC         *time.Time
        Take                   *string
    }
    
    pivotMap := make(map[string]*ShotPivot)
    
    makeKey := func(g1, g2, g3, rel, comp string) string {
        return strings.Join([]string{g1, g2, g3, rel, comp}, "|")
    }
    
    for rows.Next() {
        var r row
        if err := rows.Scan(
            &r.Group1,
            &r.Group2,
            &r.Group3,
            &r.Relation,
            &r.Component,
            &r.Phase,
            &r.WorkStatus,
            &r.ApprovalStatus,
            &r.SubmittedAtUTC,
            &r.Take,
        ); err != nil {
            return nil, fmt.Errorf("failed to scan row: %w", err)
        }
        
        key := makeKey(r.Group1, r.Group2, r.Group3, r.Relation, r.Component)
        
        // Initialize pivot if not exists
        if _, ok := pivotMap[key]; !ok {
            pivotMap[key] = &ShotPivot{
                Root:      "shots",
                Project:   project,
                Group1:    r.Group1,
                Group2:    r.Group2,
                Group3:    r.Group3,
                Relation:  r.Relation,
                Component: strings.TrimPrefix(r.Component, "_"),
                Phases:    make(map[string]PhaseData),
            }
        }
        
        // Add phase data
        phase := strings.ToLower(r.Phase)
        pivotMap[key].Phases[phase] = PhaseData{
            WorkStatus:     r.WorkStatus,
            ApprovalStatus: r.ApprovalStatus,
            SubmittedAtUTC: r.SubmittedAtUTC,
            Take:           r.Take,
        }
    }
    
    if err := rows.Err(); err != nil {
        return nil, fmt.Errorf("rows iteration error: %w", err)
    }
    
    return pivotMap, nil
}

// buildOrderedResult builds the result slice preserving the original key order
func (r *repository) buildOrderedResult(keys []shotKey, pivotMap map[string]*ShotPivot) []ShotPivot {
    makeKey := func(g1, g2, g3, rel, comp string) string {
        return strings.Join([]string{g1, g2, g3, rel, comp}, "|")
    }
    
    result := make([]ShotPivot, 0, len(keys))
    for _, k := range keys {
        key := makeKey(k.Group1, k.Group2, k.Group3, k.Relation, k.Component)
        if p, ok := pivotMap[key]; ok {
            result = append(result, *p)
        }
    }
    
    return result
}

