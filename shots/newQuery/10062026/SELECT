WITH latest_phase AS (
    SELECT project, root, group_1, group_2, group_3, relation, component,
           work_status, approval_status,
           ROW_NUMBER() OVER (
               PARTITION BY project, root, group_1, group_2, group_3, relation, component, phase
               ORDER BY modified_at_utc DESC
           ) AS rn
    FROM t_review_info
    WHERE project = 'drk' AND root = 'shots' AND deleted = 0
)
SELECT COUNT(*) FROM (
    SELECT group_1, group_2, group_3, relation, COALESCE(component, '') AS component
    FROM latest_phase
    WHERE rn = 1
      AND (work_status IN ('check') OR approval_status IN ('check'))
    GROUP BY group_1, group_2, group_3, relation, COALESCE(component, '')
) x;
