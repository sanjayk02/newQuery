router.GET("/debug/checkpivot/:project", func(c *gin.Context) {
    orderKey := c.DefaultQuery("order", "group1_only") // group1_only|group2_only|group3_only|relation_only|<phase>_take|<phase>_work|<phase>_appr|<phase>_submitted
    direction := c.DefaultQuery("direction", "asc")
    phases := c.QueryArray("phase")    // empty => fetched dynamically
    statuses := c.QueryArray("status") // empty => repo default ("check")

    items, usedPhases, total, err := reviewInfoRepository.ListReviewShotsPivot(
        c.Request.Context(), c.Param("project"),
        phases, statuses, orderKey, direction, 15, 0,
    )
    if err != nil {
        c.IndentedJSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
        return
    }
    c.IndentedJSON(http.StatusOK, gin.H{
        "phases": usedPhases, "total": total, "count": len(items), "items": items,
    })
})


