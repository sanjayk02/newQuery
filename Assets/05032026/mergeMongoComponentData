func (r *ReviewInfo) mergeMongoComponentData(
	ctx context.Context,
	rows []AssetPivot,
	project string,
) error {
	
	log.Printf("=== Starting mergeMongoComponentData ===")
	log.Printf("Project: %s, Processing %d rows", project, len(rows))
	
	// Log the first few rows to see what we're looking for
	for i, row := range rows {
		if i < 5 { // Log first 5 rows
			log.Printf("Row %d: Asset=%s, Relation=%s, Component=%s", 
				i, row.Group1, row.Relation, row.Component)
		} else {
			break
		}
	}

	mongoDocs, err := r.publishOperationInfo.ListLatestAssetComponentDocuments(
		ctx,
		&entity.LatestAssetComponentParams{
			Project: project,
			Component: []string{
				"mdlRend",
				"bldAnm",
				"bldRend",
				"ldvMdl",
			},
		},
	)
	if err != nil {
		return fmt.Errorf("failed to fetch MongoDB documents: %w", err)
	}

	log.Printf("Fetched %d MongoDB documents", len(mongoDocs))

	// If no MongoDB docs, log and return
	if len(mongoDocs) == 0 {
		log.Printf("WARNING: No MongoDB documents found for project %s", project)
		return nil
	}

	componentMap := make(map[string]map[string]*time.Time)

	// Log each MongoDB document to see their structure
	for idx, doc := range mongoDocs {
		if doc == nil || doc.LatestDocument == nil {
			log.Printf("Doc %d: nil document", idx)
			continue
		}

		groups := doc.LatestDocument.Groups
		log.Printf("Mongo Doc %d: Component=%s, Groups=%v, Relation=%s", 
			idx, doc.Component, groups, doc.LatestDocument.Relation)

		if len(groups) < 2 {
			log.Printf("  WARNING: Groups array too short: %v", groups)
			continue
		}

		// Log the groups structure to understand it
		for i, g := range groups {
			log.Printf("  groups[%d] = %s", i, g)
		}

		// Try different key constructions to see what works
		asset := groups[len(groups)-2]
		relation := groups[len(groups)-1]
		
		// Also try groups[0] as asset (since assets might be first element)
		assetAlt := groups[0]
		
		key1 := fmt.Sprintf("%s|%s", asset, relation)
		key2 := fmt.Sprintf("%s|%s", assetAlt, relation)
		
		log.Printf("  Possible keys: key1='%s', key2='%s'", key1, key2)

		// Store with both possible keys for now
		if componentMap[key1] == nil {
			componentMap[key1] = make(map[string]*time.Time)
		}
		if componentMap[key2] == nil {
			componentMap[key2] = make(map[string]*time.Time)
		}

		t := doc.LatestDocument.SubmittedAtUTC
		componentMap[key1][doc.Component] = &t
		componentMap[key2][doc.Component] = &t
		
		log.Printf("  Stored for component %s at time %v", doc.Component, t)
	}

	// Now try to match with our rows
	matchedCount := 0
	for i, row := range rows {
		key := fmt.Sprintf("%s|%s", row.Group1, row.Relation)
		
		if comp, ok := componentMap[key]; ok {
			rows[i].MDLRend = comp["mdlRend"]
			rows[i].BLDAnm = comp["bldAnm"]
			rows[i].BLDRend = comp["bldRend"]
			rows[i].LDVMdl = comp["ldvMdl"]
			matchedCount++
			
			log.Printf("✓ MATCHED: key='%s' - MDLRend=%v, BLDAnm=%v, BLDRend=%v, LDVMdl=%v",
				key,
				safeTimeFormat(rows[i].MDLRend),
				safeTimeFormat(rows[i].BLDAnm),
				safeTimeFormat(rows[i].BLDRend),
				safeTimeFormat(rows[i].LDVMdl))
		} else {
			log.Printf("✗ NO MATCH: key='%s'", key)
		}
	}
	
	log.Printf("=== mergeMongoComponentData completed. Matched %d/%d rows ===", 
		matchedCount, len(rows))

	return nil
}

func safeTimeFormat(t *time.Time) string {
	if t == nil {
		return "nil"
	}
	return t.Format("2006-01-02 15:04:05")
}
