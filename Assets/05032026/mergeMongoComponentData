func (r *ReviewInfo) mergeMongoComponentData(
	ctx context.Context,
	rows []AssetPivot,
	project string,
) error {

	mongoDocs, err := r.publishOperationInfo.ListLatestAssetDocuments(
		ctx,
		&entity.LatestAssetComponentParams{
			Project: project,
			Component: []string{
				"mdlRend",
				"bldAnm",
				"bldRend",
				"ldvMdl",
			},
		},
	)
	if err != nil {
		return err
	}

	// Build Mongo lookup map
	componentMap := map[string]map[string]*time.Time{}

	for _, doc := range mongoDocs {

		if len(doc.LatestDocument.Groups) < 2 {
			continue
		}

		asset := doc.LatestDocument.Groups[0]
		relation := doc.LatestDocument.Groups[1]

		key := asset + "|" + relation

		if componentMap[key] == nil {
			componentMap[key] = map[string]*time.Time{}
		}

		if !doc.LatestDocument.SubmittedAtUTC.IsZero() {
			componentMap[key][doc.Component] = &doc.LatestDocument.SubmittedAtUTC
		}
	}

	// Merge Mongo values into SQL rows
	for i := range rows {

		key := rows[i].Group1 + "|" + rows[i].Relation
		comp := componentMap[key]

		if comp == nil {
			continue
		}

		if t, ok := comp["mdlRend"]; ok {
			rows[i].MDLRendSubmittedAt = t
		}

		if t, ok := comp["bldAnm"]; ok {
			rows[i].BLDAnmSubmittedAt = t
		}

		if t, ok := comp["bldRend"]; ok {
			rows[i].BLDRendSubmittedAt = t
		}

		if t, ok := comp["ldvMdl"]; ok {
			rows[i].LDVMdlSubmittedAt = t
		}
	}

	return nil
}
