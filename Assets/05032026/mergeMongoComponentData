func (r *ReviewInfo) mergeMongoComponentData(
	ctx context.Context,
	rows []AssetPivot,
) error {

	mongoDocs, err := r.publishOperationInfo.ListLatestAssetDocuments(
		ctx,
		&entity.LatestAssetComponentParams{
			Component: []string{
				"mdlRend",
				"bldAnm",
				"bldRend",
				"ldvMdl",
			},
		},
	)

	if err != nil {
		return err
	}

	componentMap := map[string]map[string]*time.Time{}

	for _, doc := range mongoDocs {

		asset := doc.LatestDocument.Groups[0]

		if componentMap[asset] == nil {
			componentMap[asset] = map[string]*time.Time{}
		}

		submitted := doc.LatestDocument.SubmittedAtUTC

		componentMap[asset][doc.Component] = &submitted
	}

	for i := range rows {

		asset := rows[i].Group1

		if componentMap[asset] == nil {
			continue
		}

		rows[i].MDLRendSubmittedAt = componentMap[asset]["mdlRend"]
		rows[i].BLDAnmSubmittedAt = componentMap[asset]["bldAnm"]
		rows[i].BLDRendSubmittedAt = componentMap[asset]["bldRend"]
		rows[i].LDVMdlSubmittedAt = componentMap[asset]["ldvMdl"]
	}

	return nil
}
