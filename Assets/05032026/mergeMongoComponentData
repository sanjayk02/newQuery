func (r *ReviewInfo) mergeMongoComponentData(
	ctx context.Context,
	rows []AssetPivot,
	project string,
) error {
	
	log.Printf("=== Starting mergeMongoComponentData ===")
	log.Printf("Project: %s, Processing %d rows", project, len(rows))

	// Create a map to store component data keyed by asset|relation
	componentMap := make(map[string]map[string]*time.Time)

	// For each row, fetch its specific component data
	for _, row := range rows {
		// Skip if no asset or relation
		if row.Group1 == "" || row.Relation == "" {
			log.Printf("Skipping row with empty asset or relation: %+v", row)
			continue
		}

		log.Printf("Fetching component data for asset=%s, relation=%s", 
			row.Group1, row.Relation)

		// Fetch MongoDB documents for this specific asset and relation
		// Include both the expected names and the actual MongoDB names
		mongoDocs, err := r.publishOperationInfo.ListLatestAssetComponentDocuments(
			ctx,
			&entity.LatestAssetComponentParams{
				Project:  project,
				Asset:    row.Group1,
				Relation: row.Relation,
				Component: []string{
					// Expected names (from frontend)
					"mdlRend",
					"bldAnm",
					"bldRend",
					"ldvMdl",
					// Actual MongoDB names (from logs)
					"mdRend",
					"bldAnn",
					"lvdMl",
				},
			},
		)
		if err != nil {
			log.Printf("Error fetching for %s|%s: %v", row.Group1, row.Relation, err)
			continue
		}

		if len(mongoDocs) == 0 {
			log.Printf("No MongoDB documents found for %s|%s", row.Group1, row.Relation)
			continue
		}

		// Create key for this asset|relation
		key := fmt.Sprintf("%s|%s", row.Group1, row.Relation)
		
		if componentMap[key] == nil {
			componentMap[key] = make(map[string]*time.Time)
		}

		// Store each component's latest document
		for _, doc := range mongoDocs {
			if doc == nil || doc.LatestDocument == nil {
				continue
			}
			
			t := doc.LatestDocument.SubmittedAtUTC
			mongoComp := doc.Component
			
			log.Printf("  Raw MongoDB component: %s for %s|%s", 
				mongoComp, row.Group1, row.Relation)
			
			// Store with the original MongoDB component name
			componentMap[key][mongoComp] = &t
			
			// Map MongoDB names to expected frontend names
			switch mongoComp {
			case "mdRend":
				componentMap[key]["mdlRend"] = &t
				log.Printf("  Mapped mdRend → mdlRend for %s|%s", row.Group1, row.Relation)
			case "bldAnn":
				componentMap[key]["bldAnm"] = &t
				log.Printf("  Mapped bldAnn → bldAnm for %s|%s", row.Group1, row.Relation)
			case "lvdMl":
				componentMap[key]["ldvMdl"] = &t
				log.Printf("  Mapped lvdMl → ldvMdl for %s|%s", row.Group1, row.Relation)
			case "bldRend":
				componentMap[key]["bldRend"] = &t
			}
		}
	}

	// Now merge the data back into the rows
	matchedCount := 0
	for i := range rows {
		key := fmt.Sprintf("%s|%s", rows[i].Group1, rows[i].Relation)
		
		if comp, ok := componentMap[key]; ok {
			// Map MongoDB component names to the expected fields in AssetPivot
			
			// MDLRend - from mdRend
			if val, exists := comp["mdRend"]; exists {
				rows[i].MDLRend = val
				log.Printf("  Set MDLRend from mdRend for %s", key)
			}
			
			// BLDAnm - from bldAnn
			if val, exists := comp["bldAnn"]; exists {
				rows[i].BLDAnm = val
				log.Printf("  Set BLDAnm from bldAnn for %s", key)
			}
			
			// BLDRend - from bldRend  
			if val, exists := comp["bldRend"]; exists {
				rows[i].BLDRend = val
				log.Printf("  Set BLDRend from bldRend for %s", key)
			}
			
			// LDVMdl - from lvdMl
			if val, exists := comp["lvdMl"]; exists {
				rows[i].LDVMdl = val
				log.Printf("  Set LDVMdl from lvdMl for %s", key)
			}
			
			matchedCount++
			log.Printf("✓ Merged data for %s", key)
		} else {
			log.Printf("✗ No data found for %s", key)
		}
	}
	
	log.Printf("=== mergeMongoComponentData completed. Matched %d/%d rows ===", 
		matchedCount, len(rows))

	return nil
}
