func (r *ReviewInfo) mergeMongoComponentData(
	ctx context.Context,
	rows []AssetPivot,
	project string,
) error {

	for i := range rows {

		mongoDocs, err := r.publishOperationInfo.ListLatestAssetDocuments(
			ctx,
			&entity.LatestAssetComponentParams{
				Project: project,
				Asset:   rows[i].Group1,
				Relation: rows[i].Relation,
				Component: []string{
					"mdlRend",
					"bldAnm",
					"bldRend",
					"ldvMdl",
				},
			},
		)

		if err != nil {
			return err
		}

		for _, doc := range mongoDocs {

			submitted := doc.LatestDocument.SubmittedAtUTC

			switch doc.Component {

			case "mdlRend":
				rows[i].MDLRendSubmittedAt = &submitted

			case "bldAnm":
				rows[i].BLDAnmSubmittedAt = &submitted

			case "bldRend":
				rows[i].BLDRendSubmittedAt = &submitted

			case "ldvMdl":
				rows[i].LDVMdlSubmittedAt = &submitted
			}
		}
	}

	return nil
}
