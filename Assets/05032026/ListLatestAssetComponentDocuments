func (poi *PublishOperationInfo) ListLatestAssetComponentDocuments(
	ctx context.Context,
	param *entity.LatestAssetComponentParams,
) (documents []*entity.LatestComponentDocuments, err error) {

	log.Printf("ListLatestAssetComponentDocuments called")
	log.Printf("Project: %s", param.Project)
	log.Printf("Components: %v", param.Component)

	col := poi.db.Collection("pc_publishOperationInfo")

	// Pipeline to get latest document per component
	pipeline := mongo.Pipeline{
		// Match stage
		{
			{"$match", bson.D{
				{"_central.project", param.Project},
				{"root", "assets"},
				{"component", bson.D{{"$in", param.Component}}},
			}},
		},
		// Sort by date (newest first)
		{
			{"$sort", bson.D{
				{"submitted_at_utc", -1},
			}},
		},
		// Group by component to get latest
		{
			{"$group", bson.D{
				{"_id", "$component"},
				{"latest_document", bson.D{{"$first", "$$ROOT"}}},
			}},
		},
		// Project to reshape
		{
			{"$project", bson.D{
				{"_id", 0},
				{"component", "$_id"},
				{"latest_document", 1},
			}},
		},
	}

	cursor, err := col.Aggregate(ctx, pipeline)
	if err != nil {
		return nil, fmt.Errorf("aggregation failed: %w", err)
	}
	defer cursor.Close(ctx)

	if err = cursor.All(ctx, &documents); err != nil {
		return nil, fmt.Errorf("failed to decode results: %w", err)
	}

	if documents == nil {
		documents = []*entity.LatestComponentDocuments{}
	}

	log.Printf("Mongo documents fetched: %d", len(documents))
	
	// Debug: Log the first document's groups to verify structure
	if len(documents) > 0 && documents[0].LatestDocument != nil {
		log.Printf("Sample groups: %v", documents[0].LatestDocument.Groups)
		log.Printf("Sample relation: %s", documents[0].LatestDocument.Relation)
	}

	return documents, nil
}
