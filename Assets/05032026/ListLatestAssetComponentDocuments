func (poi *PublishOperationInfo) ListLatestAssetComponentDocuments(
	ctx context.Context,
	param *entity.LatestAssetComponentParams,
) (documents []*entity.LatestComponentDocuments, err error) {

	log.Printf("=== ListLatestAssetComponentDocuments ===")
	log.Printf("Project: %s", param.Project)
	log.Printf("Components: %v", param.Component)

	col := poi.db.Collection("pc_publishOperationInfo")

	// First, let's do a simple find to see what's in the collection
	count, err := col.CountDocuments(ctx, bson.D{
		{"_central.project", param.Project},
		{"root", "assets"},
	})
	if err != nil {
		log.Printf("Error counting documents: %v", err)
	} else {
		log.Printf("Total documents in collection for project %s: %d", param.Project, count)
	}

	// Count documents with our specific components
	for _, comp := range param.Component {
		compCount, err := col.CountDocuments(ctx, bson.D{
			{"_central.project", param.Project},
			{"root", "assets"},
			{"component", comp},
		})
		if err != nil {
			log.Printf("Error counting %s documents: %v", comp, err)
		} else {
			log.Printf("Documents with component %s: %d", comp, compCount)
		}
	}

	// Your existing pipeline
	matchStage := bson.D{
		{"$match", bson.D{
			{"_central.project", param.Project},
			{"root", "assets"},
			{"component", bson.D{{"$in", param.Component}}},
		}},
	}

	projectStage := bson.D{
		{"$project", bson.D{
			{"groups", 1},
			{"relation", 1},
			{"submitted_at_utc", 1},
			{"phase", 1},
			{"component", 1},
			{"_id", 0},
		}},
	}

	sortStage := bson.D{
		{"$sort", bson.D{
			{"submitted_at_utc", -1},
		}},
	}

	groupStage := bson.D{
		{"$group", bson.D{
			{"_id", bson.D{
				{"asset", "$groups.0"},
				{"relation", "$relation"},
				{"component", "$component"},
			}},
			{"latest_document", bson.D{{"$first", "$$ROOT"}}},
		}},
	}

	pipeline := mongo.Pipeline{
		matchStage,
		projectStage,
		sortStage,
		groupStage,
	}

	cursor, err := col.Aggregate(ctx, pipeline)
	if err != nil {
		return nil, fmt.Errorf("aggregation failed: %w", err)
	}
	defer cursor.Close(ctx)

	// Decode into a temporary struct to see the full structure
	var results []bson.M
	if err = cursor.All(ctx, &results); err != nil {
		return nil, fmt.Errorf("failed to decode results: %w", err)
	}

	log.Printf("Raw results count: %d", len(results))
	
	// Log the first few results to see structure
	for i, result := range results {
		if i < 3 {
			log.Printf("Result %d: %+v", i, result)
		}
	}

	// Now convert to your expected format
	documents = make([]*entity.LatestComponentDocuments, 0, len(results))
	for _, result := range results {
		// Extract the data based on your actual structure
		// You'll need to adapt this based on what you see in the logs
		var doc entity.LatestComponentDocuments
		
		// This is a guess - adjust based on actual structure
		if id, ok := result["_id"].(bson.M); ok {
			if comp, ok := id["component"].(string); ok {
				doc.Component = comp
			}
		}
		
		if latest, ok := result["latest_document"].(bson.M); ok {
			var latestDoc entity.LatestComponentDocument
			
			if groups, ok := latest["groups"].(bson.A); ok {
				for _, g := range groups {
					if str, ok := g.(string); ok {
						latestDoc.Groups = append(latestDoc.Groups, str)
					}
				}
			}
			
			if rel, ok := latest["relation"].(string); ok {
				latestDoc.Relation = rel
			}
			
			if submitted, ok := latest["submitted_at_utc"].(time.Time); ok {
				latestDoc.SubmittedAtUTC = submitted
			}
			
			if phase, ok := latest["phase"].(string); ok {
				latestDoc.Phase = phase
			}
			
			if comp, ok := latest["component"].(string); ok {
				latestDoc.Component = comp
			}
			
			doc.LatestDocument = &latestDoc
		}
		
		documents = append(documents, &doc)
	}

	log.Printf("Final documents count: %d", len(documents))
	return documents, nil
}
