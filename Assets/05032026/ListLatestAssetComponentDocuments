func (poi *PublishOperationInfo) ListLatestAssetComponentDocuments(
	ctx context.Context,
	param *entity.LatestAssetComponentParams,
) (documents []*entity.LatestComponentDocuments, err error) {

	log.Printf("=== ListLatestAssetComponentDocuments called ===")
	log.Printf("Project: %s", param.Project)
	log.Printf("Asset: %s", param.Asset)      // This should now have a value
	log.Printf("Relation: %s", param.Relation) // This should now have a value
	log.Printf("Components: %v", param.Component)

	// Validate required fields
	if param.Asset == "" {
		return nil, fmt.Errorf("asset is required")
	}
	if param.Relation == "" {
		return nil, fmt.Errorf("relation is required")
	}

	col := poi.db.Collection("pc_publishOperationInfo")

	// FIX: Include Asset and Relation in the match stage
	matchStage := bson.D{
		{"$match", bson.D{
			{"_central.project", param.Project},
			{"root", "assets"},
			{"groups.0", param.Asset},        // Asset is the first element in groups
			{"relation", param.Relation},      // Relation field
			{"component", bson.D{{"$in", param.Component}}},
		}},
	}

	// Project stage - include all necessary fields
	projectStage := bson.D{
		{"$project", bson.D{
			{"groups", 1},
			{"relation", 1},
			{"submitted_at_utc", 1},
			{"phase", 1},
			{"component", 1},
			{"_id", 0},
		}},
	}

	// Sort stage - newest first
	sortStage := bson.D{
		{"$sort", bson.D{
			{"submitted_at_utc", -1},
		}},
	}

	// Group stage - get the latest document for each component
	groupStage := bson.D{
		{"$group", bson.D{
			{"_id", "$component"},
			{"latest_document", bson.D{{"$first", "$$ROOT"}}},
		}},
	}

	// Project to match the expected output structure
	outputStage := bson.D{
		{"$project", bson.D{
			{"_id", 0},
			{"component", "$_id"},
			{"latest_document", 1},
		}},
	}

	pipeline := mongo.Pipeline{
		matchStage,
		projectStage,
		sortStage,
		groupStage,
		outputStage,
	}

	cursor, err := col.Aggregate(ctx, pipeline)
	if err != nil {
		return nil, fmt.Errorf("aggregation failed: %w", err)
	}
	defer cursor.Close(ctx)

	if err = cursor.All(ctx, &documents); err != nil {
		return nil, fmt.Errorf("failed to decode results: %w", err)
	}

	if documents == nil {
		documents = []*entity.LatestComponentDocuments{}
	}

	log.Printf("Mongo documents fetched: %d", len(documents))
	
	// Log sample if any documents found
	if len(documents) > 0 && documents[0].LatestDocument != nil {
		log.Printf("Sample document: Component=%s, Groups=%v, Relation=%s",
			documents[0].Component,
			documents[0].LatestDocument.Groups,
			documents[0].LatestDocument.Relation)
	}

	return documents, nil
}
