const RecordTableHead: React.FC<RecordTableHeadProps> = ({
  columns,
  currentSortKey,
  currentSortDir,
  onSortChange,
  phaseComponents,
}) => {

  const getSortDir = (key: string): SortDir =>
    currentSortKey === key ? currentSortDir : "none";

  const createSortHandler = (key: string) => () => {
    if (onSortChange) onSortChange(key);
  };

  return (
    <TableHead>
      <TableRow>

        {columns.map((column) => {

          // 🔹 Handle dynamic submitted_at columns
          if (
            column.id.endsWith("_submitted_at") &&
            !column.id.includes("_component_")
          ) {
            const phase = column.id.replace("_submitted_at", "");
            const components = phaseComponents?.[phase] || [];

            if (components.length > 0) {
              return components.map((componentName: string) => {

                const dynamicId =
                  `${phase}_${componentName.toLowerCase()}_submitted_at`;

                const sortKey =
                  `${phase}_${componentName.toLowerCase()}_submitted`;

                const sortDir = getSortDir(sortKey);

                return (
                  <TableCell
                    key={dynamicId}
                    onClick={() => createSortHandler(sortKey)()}
                    style={{
                      cursor: "pointer",
                      whiteSpace: "nowrap",
                      backgroundColor: column.colors?.backgroundColor,
                    }}
                  >
                    <Box
                      display="flex"
                      alignItems="center"
                      justifyContent="center"
                    >
                      <span style={{ fontSize: 12, fontWeight: 500 }}>
                        {`${phase.toUpperCase()} ${componentName} SUBMITTED AT`}
                      </span>

                      {sortDir !== "none" && (
                        <Box ml={0.5}>
                          <span
                            style={{
                              fontSize: 12,
                              fontWeight: "bold",
                            }}
                          >
                            {sortDir === "asc" ? "▲" : "▼"}
                          </span>
                        </Box>
                      )}
                    </Box>
                  </TableCell>
                );
              });
            }

            return null;
          }

          // 🔹 Normal column rendering
          const sortKey = column.sortKey || column.id;
          const sortDir = getSortDir(sortKey);

          return (
            <TableCell
              key={column.id}
              onClick={column.sortable ? createSortHandler(sortKey) : undefined}
              style={{
                cursor: column.sortable ? "pointer" : "default",
                whiteSpace: "nowrap",
                backgroundColor: column.colors?.backgroundColor,
              }}
            >
              <Box display="flex" alignItems="center" justifyContent="center">
                <span style={{ fontSize: 12, fontWeight: 500 }}>
                  {column.label}
                </span>

                {sortDir !== "none" && (
                  <Box ml={0.5}>
                    <span
                      style={{
                        fontSize: 12,
                        fontWeight: "bold",
                      }}
                    >
                      {sortDir === "asc" ? "▲" : "▼"}
                    </span>
                  </Box>
                )}
              </Box>
            </TableCell>
          );
        })}

      </TableRow>
    </TableHead>
  );
};
