const allAssets = useMemo(() => {
  let list = [];

  if (viewMode === "grouped") {
    list = (groups || []).flatMap((g: any) => g.items || []);
  } else {
    list = assets || rawAssets || [];
  }

  // remove duplicates
  const map = new Map();
  list.forEach(a => {
    map.set(`${a.group_1}-${a.relation}`, a);
  });

  return Array.from(map.values());
}, [viewMode, groups, assets, rawAssets]);
