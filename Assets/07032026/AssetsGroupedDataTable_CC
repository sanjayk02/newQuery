// Column IDs are dynamic (driven by phaseComponents config), so we use a plain string
// rather than a fixed union type that would need updating per project.
type ColumnId = string;

type Column = {
  id: ColumnId;
  label: string;
  sortable?: boolean;
  phase?: keyof typeof COLORS.PHASE; // mdl|rig|bld|dsn|ldv
  kind?: "work" | "appr" | "submitted" | "take";
  isComponent?: boolean; // true for dynamic component columns (mdlRend, bldAnm, etc.)
  headerMode?: "phaseKind" | "label";
};

const getSortValue = (
  asset: any,
  key: string,
  latestComponents?: Record<string, any>
) => {
  // TAKE → numeric
  const takeMatch = key.match(/^(mdl|rig|bld|dsn|ldv)_take$/i);
  if (takeMatch) {
    const val = asset[key];
    return val ? parseInt(String(val).replace(/\D/g, ""), 10) : 0;
  }

  // Phase Submitted
  if (key.includes("_submitted")) {
    const date = new Date(asset[key + "_at_utc"] || asset[key]);
    return isNaN(date.getTime()) ? 0 : date.getTime();
  }

  // Component submitted columns — match by component name (works for any project config)
  if (latestComponents) {
    const cleanRelation = (asset.relation || "").toString().trim();
    const assetKey = `${asset.group_1}-${cleanRelation}`;
    const componentList: any[] = latestComponents[assetKey] || [];

    const componentItem =
      componentList.find((item: any) => item.component === key) ||
      componentList.find((item: any) => item.component && item.component.toLowerCase() === key.toLowerCase());

    if (componentItem && componentItem.latest_document && componentItem.latest_document.submitted_at_utc) {
      const date = new Date(componentItem.latest_document.submitted_at_utc);
      return isNaN(date.getTime()) ? 0 : date.getTime();
    }
  }

  // Default string sort
  return asset[key] || "";
};

type Props = {
  groups?: PivotGroup[];

  // sorting
  sortKey: string;
  sortDir: SortDir;
  onSortChange: (key: string) => void;

