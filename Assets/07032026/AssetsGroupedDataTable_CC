   * Drives which component columns appear in the table.
   * e.g. { mdl: ['mdlRend', 'mdlAnm'], bld: ['bldAnm', 'bldRend'] }
   */
  phaseComponents?: { [phase: string]: string[] };
};

/**
 * Returns the dynamic component columns for a given phase, based on the
 * project's pipeline configuration. Mirrors the pattern in AssetsDataTable.tsx.
 */
function buildComponentColumns(
  phase: keyof typeof COLORS.PHASE,
  phaseComponents: { [phase: string]: string[] } | undefined,
): Column[] {
  const componentIds = (phaseComponents && phaseComponents[phase]) || [];
  return componentIds.map((id) => ({
    id,
    label: `${id.toUpperCase()} Submitted`,
    sortable: true,
    phase,
    isComponent: true,
    headerMode: "label" as const,
  }));
}

/**
