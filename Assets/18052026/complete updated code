/* Toggle column visibility - saves ONLY to state, NO persistence */
const toggleColumn = (id: string) => {
  if (FIXED_VISIBLE.has(id)) return;
  setHiddenColumns((prev) => {
    const next = new Set(prev);
    if (next.has(id)) {
      next.delete(id);
      console.log(`Showing column: ${id}`);
    } else {
      next.add(id);
      console.log(`Hiding column: ${id}`);
    }
    // ❌ NO save to localStorage
    // ❌ NO save to pipeline
    // Only update state
    return next;
  });
};

/* Show all columns - updates state only */
const showAll = () => {
  const next = new Set<string>();
  setHiddenColumns(next);
  console.log('Showing all columns (state only - click SAVE to persist)');
};

/* Hide all non-fixed columns - updates state only */
const hideAllNonFixed = () => {
  const phases = ['dsn', 'mdl', 'rig', 'bld', 'ldv'];
  const dynamicIds: string[] = [
    'dsn_approval_status', 'dsn_work_status', 'dsn_take',
    'mdl_approval_status', 'mdl_work_status', 'mdl_take',
    'rig_approval_status', 'rig_work_status', 'rig_take',
    'bld_approval_status', 'bld_work_status', 'bld_take',
    'ldv_approval_status', 'ldv_work_status', 'ldv_take',
    'relation',
  ];
  if (phaseComponents) {
    phases.forEach(phase => {
      const ids = phaseComponents[phase] || [];
      ids.forEach(id => dynamicIds.push(id));
    });
  }
  const next = new Set<string>(dynamicIds.filter(id => !FIXED_VISIBLE.has(id)));
  setHiddenColumns(next);
  console.log('Hiding all non-fixed columns (state only - click SAVE to persist)');
};

/* Save to pipeline settings (ONLY called by SAVE button) */
const saveHiddenColumnsToPipelineSetting = async (cols: Set<string>) => {
  try {
    if (!currentProject || !currentProject.key_name) return;
    
    console.log('💾 SAVE button clicked - saving to pipeline settings...');
    
    const { updateValue } = await import('../../../new-pipeline-setting/api');
    const { GROUP, SECTION } = await import('../../../new-pipeline-setting/types');
    
    const columnsArray = Array.from(cols);
    
    await updateValue(
      PIPE_KEY,
      columnsArray,
      GROUP.Preference,
      SECTION.Project,
      currentProject.key_name,
    );
    
    console.log('✅ Pipeline settings save successful');
  } catch (e) {
    console.error('❌ PipelineSetting save failed:', e);
  }
};

/* Handle SAVE button click */
const handleSaveColumns = async () => {
  await saveHiddenColumnsToPipelineSetting(hiddenColumns);
};
