/* Load hidden columns from pipeline settings - FIXED version */
useEffect(() => {
  let isMounted = true;
  
  const loadFromPipeline = async () => {
    if (!currentProject) return;
    
    const projectKey = currentProject.key_name;
    console.log('Loading column visibility from PIPELINE SETTINGS for project:', projectKey);
    
    try {
      // Import required modules
      const { getAuthHeader, setNewToken } = await import('../../../auth/util');
      const { AuthorizationError } = await import('../../../auth/types');
      
      const headers = getAuthHeader();
      const encodedKey = encodeURIComponent(PIPE_KEY);
      const url = `/api/pipelineSetting/preference/projects/${encodeURIComponent(projectKey)}/values/${encodedKey}`;
      
      console.log('Fetching from URL:', url);
      
      const response = await fetch(url, {
        method: 'GET',
        headers,
        mode: 'cors',
      });
      
      if (response.status === 401) {
        throw new AuthorizationError();
      }
      
      if (response.status === 404) {
        console.log('No saved settings found in pipeline (404)');
        if (isMounted) {
          setHiddenColumns(new Set());
        }
        return;
      }
      
      if (!response.ok) {
        throw new Error(`Failed to fetch: ${response.status}`);
      }
      
      setNewToken(response);
      const json = await response.json();
      const savedValue = json.value;
      
      console.log('Pipeline settings response:', savedValue);
      
      if (savedValue && Array.isArray(savedValue) && isMounted) {
        const sanitized = savedValue.filter((id: string) => !FIXED_VISIBLE.has(id));
        setHiddenColumns(new Set(sanitized));
        console.log('✅ Loaded column visibility from PIPELINE SETTINGS:', sanitized);
      } else if (isMounted) {
        console.log('No valid saved settings found, using defaults');
        setHiddenColumns(new Set());
      }
    } catch (error) {
      console.error('Pipeline settings load failed:', error);
      if (isMounted) {
        console.log('Using default column visibility (all columns visible)');
        setHiddenColumns(new Set());
      }
    }
  };
  
  loadFromPipeline();
  
  return () => {
    isMounted = false;
  };
}, [currentProject]);


/* Save to pipeline settings (called by SAVE button) */
const saveHiddenColumnsToPipelineSetting = async (cols: Set<string>) => {
  try {
    if (!currentProject || !currentProject.key_name) return;
    
    console.log('💾 SAVE button clicked - saving to pipeline settings...');
    
    const { getAuthHeader, setNewToken } = await import('../../../auth/util');
    const { AuthorizationError } = await import('../../../auth/types');
    
    const headers = getAuthHeader();
    const encodedKey = encodeURIComponent(PIPE_KEY);
    const url = `/api/pipelineSetting/preference/projects/${encodeURIComponent(currentProject.key_name)}/values/${encodedKey}`;
    
    const columnsArray = Array.from(cols);
    
    const response = await fetch(url, {
      method: 'PATCH',
      headers: {
        ...headers,
        'Content-Type': 'application/json',
      },
      mode: 'cors',
      body: JSON.stringify({ value: columnsArray }),
    });
    
    if (response.status === 401) {
      throw new AuthorizationError();
    }
    
    if (!response.ok) {
      throw new Error(`Failed to save: ${response.status}`);
    }
    
    setNewToken(response);
    console.log('✅ Pipeline settings save successful');
  } catch (e) {
    console.error('❌ PipelineSetting save failed:', e);
  }
};




/* Toggle column visibility - ONLY updates state, NO persistence */
const toggleColumn = (id: string) => {
  if (FIXED_VISIBLE.has(id)) return;
  setHiddenColumns((prev) => {
    const next = new Set(prev);
    if (next.has(id)) {
      next.delete(id);
      console.log(`Showing column: ${id}`);
    } else {
      next.add(id);
      console.log(`Hiding column: ${id}`);
    }
    // NO save - just update UI
    return next;
  });
};
