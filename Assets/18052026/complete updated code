/* Load hidden columns - ONLY from pipeline settings (NO localStorage) */
useEffect(() => {
  let aborted = false;
  
  (async () => {
    if (!currentProject) return;
    
    const projectKey = currentProject.key_name;
    
    console.log('Loading column visibility from PIPELINE SETTINGS for project:', projectKey);
    
    try {
      const { queryValue } = await import('../../../new-pipeline-setting/api');
      const { GROUP, SECTION } = await import('../../../new-pipeline-setting/types');
      
      const savedValue = await queryValue(
        GROUP.Preference,
        SECTION.Project,
        projectKey,
        PIPE_KEY,
      );
      
      console.log('Pipeline settings response:', savedValue);
      
      if (savedValue && Array.isArray(savedValue)) {
        const sanitized = savedValue.filter((id: string) => !FIXED_VISIBLE.has(id));
        if (!aborted) {
          setHiddenColumns(new Set(sanitized));
          console.log('✅ Loaded column visibility from PIPELINE SETTINGS:', sanitized);
        }
        return;
      } else {
        console.log('No saved column visibility found in pipeline settings, using defaults');
      }
    } catch (pipeError) {
      console.warn('Pipeline settings load failed:', pipeError);
    }
    
    // Default: empty set (all columns visible)
    if (!aborted) {
      console.log('Using default column visibility (all columns visible)');
      setHiddenColumns(new Set());
    }
  })();
  
  return () => {
    aborted = true;
  };
}, [currentProject]);

