const saveHiddenColumnsToPipelineSetting = async (cols: Set<string>) => {
  try {
    if (!currentProject || !currentProject.key_name) return;
    
    console.log('Saving hidden columns to pipeline settings...');
    
    // Import the updateValue function
    const { updateValue } = await import('../../../new-pipeline-setting/api');
    const { GROUP, SECTION } = await import('../../../new-pipeline-setting/types');
    
    // Convert Set to Array for storage
    const columnsArray = Array.from(cols);
    
    console.log('Saving:', {
      key: PIPE_KEY,
      value: columnsArray,
      group: GROUP.Preference,
      section: SECTION.Project,
      entry: currentProject.key_name
    });
    
    await updateValue(
      PIPE_KEY, // key
      columnsArray, // value (array of strings)
      GROUP.Preference, // group
      SECTION.Project, // section
      currentProject.key_name, // entry (project name)
    );
    
    console.log('✅ Pipeline settings save successful');
  } catch (e) {
    console.error('❌ PipelineSetting save failed:', e);
    console.warn('Using local only');
  }
};



const toggleColumn = (id: string) => {
  if (FIXED_VISIBLE.has(id)) return;
  setHiddenColumns((prev) => {
    const next = new Set(prev);
    if (next.has(id)) {
      next.delete(id);
      console.log(`Showing column: ${id}`);
    } else {
      next.add(id);
      console.log(`Hiding column: ${id}`);
    }
    persistHiddenColumns(next);
    return next;
  });
};
