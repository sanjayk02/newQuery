// ================= COMPONENT HELPERS =================

const getComponentCellData = (
  asset: any,
  componentName: string
) => {
  const assetKey = `${asset.group_1}-${asset.relation}`;
  const componentList = latestComponents?.[assetKey] || [];

  const item = componentList.find(
    (x: any) => x.component === componentName
  );

  if (!item?.latest_document) {
    return null;
  }

  const doc = item.latest_document;

  return {
    component: doc.component ?? componentName,
    phase: doc.phase ?? "—",
    submittedAt: doc.submitted_at_utc ?? null,
  };
};


const getComponentTooltip = (
  asset: any,
  componentName: string
): string => {
  const data = getComponentCellData(asset, componentName);

  if (!data) {
    return "No submission available";
  }

  const submittedText = data.submittedAt
    ? dateTimeFormat.format(new Date(data.submittedAt))
    : "—";

  return [
    `Component: ${data.component}`,
    `Phase: ${data.phase}`,
    `Submitted: ${submittedText}`,
  ].join("\n");
};


const getComponentDisplayText = (
  asset: any,
  componentName: string
): string => {
  const data = getComponentCellData(asset, componentName);

  if (!data?.submittedAt) return "—";

  return dateTimeFormat.format(new Date(data.submittedAt));
};



